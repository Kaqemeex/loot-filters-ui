{
    "name": "@loot-filters/api",
    "version": "1.0.0",
    "description": "Cloudflare Worker API for loot filters with D2 database",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.js"
        }
    },
    "scripts": {
        "build": "tsc",
        "dev": "wrangler dev",
        "deploy": "wrangler deploy",
        "clean": "rm -rf dist",
        "type-check": "tsc --noEmit",
        "lint": "eslint src --ext .ts",
        "test": "wrangler dev --test-scheduled",
        "db:migrate": "wrangler d1 migrations apply loot-filters-v2"
    },
    "dependencies": {
        "@loot-filters/core": "file:../core",
        "drizzle-orm": "^0.44.5",
        "itty-router": "^5.0.22",
        "zod": "^3.22.3"
    },
    "devDependencies": {
        "@cloudflare/workers-types": "^4.20241218.0",
        "drizzle-kit": "^0.31.4",
        "typescript": "5.3.3",
        "wrangler": "^4.33.1"
    }
}
